# Next.js web 应用 - 多阶段构建
# 构建在本地/CI 执行，服务器只运行镜像

# syntax=docker/dockerfile:1
# Stage 1: 安装依赖（指定 amd64，Mac 构建后可在 x86 服务器运行）
FROM --platform=linux/amd64 node:20-alpine AS deps
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@10.29.3 --activate
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json apps/web/
COPY packages/ packages/
# BuildKit 缓存 pnpm store，二次构建显著加速
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile

# Stage 2: 构建
FROM --platform=linux/amd64 node:20-alpine AS builder
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@10.29.3 --activate
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/package.json ./package.json
COPY --from=deps /app/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=deps /app/pnpm-workspace.yaml ./pnpm-workspace.yaml
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY . .
# 从 deps 覆盖 packages/，保留 pnpm install 生成的 node_modules（含 clsx/date-fns/tailwind-merge 等）
COPY --from=deps /app/packages ./packages
ENV NEXT_PUBLIC_BASE_PATH=/web
# 生产环境：SSR 时 web 容器需通过 Docker 网络访问 java 服务
ENV NEXT_PUBLIC_API_BASE=http://java:4300
RUN pnpm --filter web build

# Stage 3: 运行
FROM --platform=linux/amd64 node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

RUN addgroup -g 1001 -S nodejs && adduser -S nextjs -u 1001

# Next.js standalone 输出结构
COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

USER nextjs

EXPOSE 3000

CMD ["node", "apps/web/server.js"]
